  "keyFeatures": [
    "GUI file transfer client for macOS and Windows",
    "CLI (duck) for Linux, macOS, and Windows",
    "Supports FTP, FTPS, SFTP, WebDAV, and 15+ cloud storage providers",
    "Cryptomator vault integration for end-to-end encryption",
    "Connection profiles for easy server configuration",
    "Bookmark management for saved connections",
    "Folder synchronization",
    "CDN integration (CloudFront invalidation)",
    "OAuth 2.0 authentication for cloud providers",
    "SSH key and certificate-based authentication"
  ],
  "publicApiSurface": [
    "duck --upload <url> <file>",
    "duck --download <url> <file>",
    "duck --list <url>",
    "duck --longlist <url>",
    "duck --delete <url>",
    "duck --mkdir <url>",
    "duck --copy <url> <url>",
    "duck --move <url> <file>",
    "duck --synchronize <url> <directory>",
    "duck --purge <url>",
    "duck --username / --password / --identity",
    "duck --profile <profile>",
    "duck --vault <path>",
    "duck --existing <action>",
    "duck --parallel <connections>",
    "duck --throttle <bytes-per-second>",
    "duck --preserve",
    "duck --retry [count]",
    "duck --verbose / --quiet / --debug"
